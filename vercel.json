{
    "version": 2,
    "builds": [
      {
        "src": "app.py",
        "use": "@vercel/python",
        "config": {
          "maxLambdaSize": "50mb",
          "runtime": "python3.9"  
        }
      }
    ],
    "routes": [
      {
        "src": "/(.*)",
        "dest": "app.py"
      }
    ],
    "env": {
      "GOOGLE_APPLICATION_CREDENTIALS_BASE64": "GOOGLE_APPLICATION_CREDENTIALS_BASE64",
      "GEMINI_API_KEY": "GEMINI_API_KEY"
    }
  }
  
